APP_NAME="GROM Web"
APP_ENV=local
APP_DEBUG=true
APP_URL=https://grom.local

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=grom_web
DB_USERNAME=grom_app
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

REPORT_STORAGE_DISK=private_reports
REPORT_STORAGE_PATH=/var/www/storage/app/private/reports

SECURITY_REQUIRE_MFA_FOR_ADMINS=true
SECURITY_FORCE_HTTPS=true
SECURITY_REMOTE_ADMIN_ALLOWLIST=

