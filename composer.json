{
  "name": "grom/web-php",
  "description": "Reconstrucao assistida do GROM em plataforma web PHP.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "laravel/framework": "^12.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Grom\\": "app/"
    }
  },
  "scripts": {
    "test": [
      "@php vendor/bin/phpunit"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

