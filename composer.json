{
  "name": "grom/web-php",
  "description": "Reconstrucao assistida do GROM em plataforma web PHP.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "laravel/framework": "13.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "laravel/pail": "^1.2",
    "laravel/tinker": "^3.0",
    "nunomaduro/termwind": "^2.4",
    "nunomaduro/collision": "^8.9"
  },
  "autoload": {
    "psr-4": {
      "Grom\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "runtime/tests/"
    }
  },
  "scripts": {
    "test": [
      "@php vendor/bin/phpunit"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
